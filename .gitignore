# Environment files (contain secrets)
.env
*.env
!.env.example

# Data directories (should be on persistent disk in production)
data/

# Terraform
terraform/.terraform/
terraform/*.tfstate
terraform/*.tfstate.*
terraform/*.tfvars
!terraform/*.tfvars.example
terraform/.terraform.lock.hcl
terraform/crash.log

# Credentials (never commit these!)
*.json
!package.json
terraform-*.json
*-key.json

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Logs
*.log
