{
    email {$ADMIN_EMAIL:admin@example.com}
}

# Main domain block - only used when DOMAIN is a real hostname (not IP)
# For IP addresses, use the :80 block below
{$DOMAIN:localhost} {
    reverse_proxy ghost:2368

    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }

    encode gzip

    log {
        output stdout
        format json
    }
}

# Handle nip.io domains for staging (with self-signed cert)
*.nip.io {
    reverse_proxy ghost:2368

    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        -Server
    }

    encode gzip

    tls internal
}

# HTTP access for direct IP (no SSL)
:80 {
    reverse_proxy ghost:2368

    header {
        X-Content-Type-Options "nosniff"
        -Server
    }
}
