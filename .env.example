# Ghost Configuration
# Copy this to clients/clientname.env and fill in your values
# Then upload to Secret Manager:
# ./scripts/upload-secret.sh clientname clients/clientname.env

# Ghost URL (full URL with protocol)
# For IP access: http://YOUR_STATIC_IP
# For custom domain: https://blog.yourdomain.com
GHOST_URL=http://localhost

# Caddy domain (controls SSL provisioning)
# For IP access: localhost (uses HTTP only)
# For custom domain: blog.yourdomain.com (enables auto-SSL)
DOMAIN=localhost

# MySQL Configuration (auto-generated by create-client-env.sh)
MYSQL_ROOT_PASSWORD=your-secure-root-password
MYSQL_DATABASE=ghost
MYSQL_USER=ghost
MYSQL_PASSWORD=your-secure-ghost-password

# Email Configuration (optional)
# GHOST_MAIL_TRANSPORT=SMTP
# GHOST_MAIL_FROM=noreply@yourdomain.com
# GHOST_MAIL_SERVICE=Mailgun
# GHOST_MAIL_USER=postmaster@yourdomain.com
# GHOST_MAIL_PASS=your-mailgun-password

# Admin email for SSL certificates
ADMIN_EMAIL=admin@yourdomain.com
